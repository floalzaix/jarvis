# Copy this file to `.env` at the project root and fill in your values.
# The app reads these variables through `config/config.py` (pydantic-settings).
# Variables marked as required have no default — the app will not start without them.

# --- Environment ---

# App runtime mode. Use "development" locally, "production" when deployed.
APP_ENV=development

# --- LLM (Ollama) ---

# Ollama model name used for chat responses (must be pulled in Ollama first).
# Example: ollama pull qwen3:8b
MODEL=qwen3:8b

# Enable the model "thinking" mode if supported (true/false).
THINK=false

# Port where your local Ollama server listens (default Ollama port is 11434).
OLLAMA_PORT=11434

# --- Context window (token budget) ---
#
# These three values control how much text is sent to the model on each request.
# They are counted with tiktoken (cl100k_base encoding).
#
# Rule: NB_INSTRUCT_TOKENS + NB_HISTORY_TOKENS must be <= NB_CTX_TOKENS
#
# - NB_CTX_TOKENS      → total context size passed to Ollama (num_ctx option)
# - NB_INSTRUCT_TOKENS → budget for system prompt, skills, rules, ...
# - NB_HISTORY_TOKENS  → budget for chat history, facts memory and user input
#
# If the history exceeds NB_HISTORY_TOKENS, older messages are dropped
# automatically (see models/inference_payload.py).

NB_CTX_TOKENS=8192
NB_INSTRUCT_TOKENS=2048
NB_HISTORY_TOKENS=6144

# --- Embedder (used by Graphiti / facts memory) ---

# Ollama embedding model (must be pulled in Ollama first).
# Example: ollama pull nomic-embed-text
EMBEDDER_MODEL=nomic-embed-text

# Embedding vector size — must match the model you use.
EMBEDDER_DIM=768

# --- Long-term memory (SQL database) ---

# Stores users, chat sessions and message history.
# SQLite (simplest for local dev):
LT_MEMORY_DATABASE_URL=sqlite:///./jarvis_memory.db
# PostgreSQL example:
# LT_MEMORY_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/jarvis

# --- Facts memory (Neo4j graph database) ---

# Neo4j Bolt URL used by Graphiti to store extracted facts and relations.
FACTS_MEMORY_DATABASE_URL=bolt://localhost:7687

# Neo4j credentials (default for a fresh local Neo4j install is often neo4j / a password you set on first login).
FACTS_MEMORY_USERNAME=neo4j
FACTS_MEMORY_PASSWORD=your_neo4j_password
